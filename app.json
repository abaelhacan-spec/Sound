{
  "expo": {
    "name": "Sound Monitor",
    "slug": "monitor-sound-",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "backgroundColor": "#1a1a1a"
    },
    "assetBundlePatterns": ["**/*"],
    "android": {
      "package": "com.monitorapp.soundmonitor",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a1a"
      },
      "permissions": [
        "RECORD_AUDIO",
        "CALL_PHONE",
        "WAKE_LOCK",
        "FOREGROUND_SERVICE"
      ]
    },
    "plugins": [
      [
        "expo-av",
        {
          "microphonePermission": "يحتاج هذا التطبيق الوصول للمايكروفون لمراقبة الأصوات."
        }
      ],
      "react-native-fast-tflite"
    ],
    "extra": {
      "eas": {
        "projectId": "ae5018d2-7502-478e-8ac5-c2e60f2a3f40"
      }
    }
  }
}
